{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A PC component in the inventory",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "quantity": { "type": "number", "description": "Available stock quantity" }
      },
      "required": ["name", "category", "price", "quantity"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order containing multiple products",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "timestamp": { "type": "number" },
        "totalPrice": { "type": "number" },
        "userId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" }
            },
            "required": ["productId", "name", "price", "quantity"]
          }
        }
      },
      "required": ["date", "totalPrice", "items", "userId"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Stores the PC inventory items"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Stores customer orders"
    }
  }
}
